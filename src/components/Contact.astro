---
const socials = [
  {
    label: 'GitHub',
    href: '#',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: '#',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`,
  },
  {
    label: 'Twitter / X',
    href: '#',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<section id="contact" class="py-32 px-6 bg-zinc-900/30">
  <div class="max-w-2xl mx-auto text-center reveal">
    <p class="font-mono text-accent-light text-xs tracking-widest uppercase mb-4">06. Contact</p>
    <h2 class="text-3xl md:text-4xl font-bold text-zinc-100 mb-4">Get In Touch</h2>
    <p class="text-zinc-400 leading-relaxed mb-10">
      I'm currently open to new opportunities. Whether you have a question, a project idea,
      or just want to say hi — my inbox is always open.
    </p>

    <a
      href="mailto:hello@example.com"
      class="inline-block px-8 py-4 border border-accent text-accent-light hover:bg-accent/10 rounded-lg font-mono text-sm transition-all duration-200 hover:shadow-lg hover:shadow-accent/10 mb-16"
    >
      Say Hello →
    </a>

    <!-- Social links -->
    <div class="flex justify-center gap-6">
      {socials.map(s => (
        <a
          href={s.href}
          aria-label={s.label}
          class="w-10 h-10 flex items-center justify-center text-zinc-500 hover:text-zinc-100 transition-all duration-200 hover:-translate-y-1"
        >
          <span class="w-5 h-5" set:html={s.icon} />
        </a>
      ))}
    </div>
  </div>

  <!-- Footer -->
  <div class="mt-24 text-center">
    <p class="font-mono text-zinc-600 text-xs">
      Designed & built by <span class="text-zinc-500">CoMaE</span> · Powered by
      <span class="text-zinc-500">Astro</span>
    </p>
  </div>
</section>
