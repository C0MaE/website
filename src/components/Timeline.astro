---
const events = [
  {
    year: 'May 2020',
    title: 'First Line of Code',
    place: 'Home',
    description: 'Got into programming through Java — starting with a Minecraft server. That rabbit hole never really ended.',
    type: 'milestone',
  },
  {
    year: 'Jan 2024',
    title: 'First Open Source Project',
    place: 'GitHub',
    description: 'Built a fullstack tournament management app in Rust and React — my first real dive into both the language and open source.',
    type: 'milestone',
  },
  {
    year: 'Jul 2024',
    title: 'Junior Developer at BEYONDIT GmbH',
    place: 'Kiel',
    description: 'Started my first professional role as a developer, working on real-world fullstack projects in a team environment.',
    type: 'work',
  },
  {
    year: 'Jun 2025',
    title: 'High School Graduation (Abitur)',
    place: 'Northern Germany',
    description: 'Finished school — with coding already a bigger part of my life than most of my classes.',
    type: 'graduation',
  },
  {
    year: 'Present',
    title: 'Physics Student',
    place: 'Christian-Albrechts-Universität Kiel',
    description: 'Studying physics at CAU Kiel, bridging the gap between scientific thinking and software — simulations, data analysis, and everything in between.',
    type: 'education',
  },
];

const typeColors: Record<string, string> = {
  education: 'bg-accent border-accent/50 text-white',
  work: 'bg-emerald-600 border-emerald-500/50 text-white',
  milestone: 'bg-zinc-700 border-zinc-600 text-zinc-200',
  graduation: 'bg-amber-600 border-amber-500/50 text-white',
};

const typeDot: Record<string, string> = {
  education: 'bg-accent shadow-accent/40',
  work: 'bg-emerald-500 shadow-emerald-500/40',
  milestone: 'bg-zinc-500 shadow-zinc-500/40',
  graduation: 'bg-amber-500 shadow-amber-500/40',
};
---

<section id="timeline" class="py-32 px-6 bg-zinc-900/30">
  <div class="max-w-3xl mx-auto">
    <div class="reveal mb-16">
      <p class="font-mono text-accent-light text-xs tracking-widest uppercase mb-4">05. Journey</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100">My timeline</h2>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-t from-accent/40 via-zinc-700 to-transparent -translate-x-1/2" />

      <div class="space-y-10">
        {events.map((event, i) => (
          <div class={`reveal relative flex items-start gap-6 md:gap-0 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>

            <!-- Dot -->
            <div class={`relative z-10 flex-shrink-0 w-8 h-8 md:absolute md:left-1/2 md:-translate-x-1/2 rounded-full flex items-center justify-center shadow-lg ${typeDot[event.type]} ${event.year === 'Present' ? 'animate-pulse' : ''}`}>
              {event.type === 'education' && (
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422A12.083 12.083 0 0121 13c0 3.866-4.03 7-9 7S3 16.866 3 13a12.083 12.083 0 012.84-1.422L12 14z"/>
                </svg>
              )}
              {event.type === 'work' && (
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
              )}
              {event.type === 'milestone' && (
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
              )}
              {event.type === 'graduation' && (
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422A12.083 12.083 0 0121 13c0 3.866-4.03 7-9 7S3 16.866 3 13a12.083 12.083 0 012.84-1.422L12 14z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14V7"/>
                </svg>
              )}
            </div>

            <!-- Card -->
            <div class={`flex-1 md:w-[calc(50%-2.5rem)] md:max-w-[calc(50%-2.5rem)] ml-2 md:ml-0 ${i % 2 === 0 ? 'md:pr-12' : 'md:pl-12'}`}>
              <div class={`relative bg-zinc-900 border rounded-xl p-5 transition-colors duration-200 ${event.year === 'Present' ? 'border-accent/50 hover:border-accent shadow-lg shadow-accent/10' : 'border-zinc-800 hover:border-zinc-700'}`}>
                {event.year === 'Present' && (
                  <div class="absolute -inset-px rounded-xl bg-accent/5 blur-sm -z-10" />
                )}
                <div class="flex items-start justify-between gap-3 mb-2 flex-wrap">
                  <h3 class="font-semibold text-zinc-100">{event.title}</h3>
                  <span class={`text-xs font-mono px-2 py-0.5 rounded-full border ${typeColors[event.type]}`}>
                    {event.year}
                  </span>
                </div>
                <p class="text-xs font-mono text-zinc-500 mb-2">{event.place}</p>
                <p class="text-zinc-400 text-sm leading-relaxed">{event.description}</p>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </div>
</section>
