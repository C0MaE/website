---
const projects = [
  {
    title: 'TAP – Tournament Manager',
    description: 'Full-stack tournament management platform with a Rust (Actix-web) REST API, JWT authentication, and a Next.js frontend. Backed by PostgreSQL via SeaORM and containerised with Docker.',
    tags: ['Rust', 'Next.js', 'TypeScript', 'PostgreSQL', 'Docker'],
    github: '#',
    live: null,
    featured: true,
  },
  {
    title: 'Open DnD',
    description: 'A developer productivity CLI written in Go. Automates repetitive tasks and integrates with popular APIs.',
    tags: ['Rust', 'Tauri', 'React'],
    github: '#',
    image: '/open-dnd.png',
    live: null,
    featured: true,
  },
  {
    title: 'McLookup',
    description: 'A small utility library for Looking up Minecraft Character Data in Kotlin',
    tags: ['Kotlin', 'gradle'],
    github: 'https://github.com/C0MaE/McLookup',
    live: null,
    featured: false,
  },
  {
    title: 'JDA Command Manager',
    description: 'A minimal, fast Command Manager for the Discord API - JDA.',
    tags: ['Kotlin', 'Discord', 'JDA'],
    github: 'https://github.com/C0MaE/JDACommandManager',
    live: null,
    featured: false,
  }
];
---

<section id="projects" class="py-32 px-6 bg-zinc-900/30">
  <div class="max-w-5xl mx-auto">
    <div class="reveal mb-16">
      <p class="font-mono text-accent-light text-xs tracking-widest uppercase mb-4">02. Projects</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100">Things I've built</h2>
    </div>

    <!-- Featured projects -->
    <div class="space-y-8 mb-16">
      {projects.filter(p => p.featured).map((project, i) => (
        <div class={`reveal group grid md:grid-cols-2 gap-6 bg-zinc-900 border border-zinc-800 rounded-2xl p-6 hover:border-zinc-700 transition-all duration-300 hover:shadow-xl hover:shadow-black/20 ${i % 2 === 1 ? 'md:[&>div:first-child]:order-2' : ''}`}>
          <!-- Info -->
          <div class="flex flex-col justify-center">
            <p class="font-mono text-accent-light text-xs tracking-wider mb-2">Featured Project</p>
            <h3 class="text-xl font-bold text-zinc-100 mb-3 group-hover:text-white transition-colors">
              {project.title}
            </h3>
            <p class="text-zinc-400 text-sm leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map(tag => (
                <span class="font-mono text-xs px-2 py-1 bg-zinc-800 text-zinc-400 rounded-md">{tag}</span>
              ))}
            </div>
            <div class="flex gap-4">
              <a href={project.github} class="text-zinc-400 hover:text-zinc-100 transition-colors" aria-label="GitHub">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </a>
              {project.live && (
                <a href={project.live} class="text-zinc-400 hover:text-zinc-100 transition-colors" aria-label="Live demo">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>

          <!-- Preview -->
          <div class="rounded-xl h-48 md:h-full overflow-hidden border border-zinc-700/50 group-hover:border-zinc-600 transition-colors min-h-[180px]">
            {project.image ? (
              <img
                src={project.image}
                alt={`${project.title} preview`}
                class="w-full h-full object-cover object-top"
              />
            ) : (
              <div class="w-full h-full bg-zinc-800 flex items-center justify-center text-zinc-600">
                <svg class="w-12 h-12 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Other projects grid -->
    <div class="reveal mb-8">
      <h3 class="text-lg font-semibold text-zinc-300">Other noteworthy projects</h3>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.filter(p => !p.featured).map(project => (
        <div class="reveal group bg-zinc-900 border border-zinc-800 rounded-xl p-5 hover:border-zinc-700 hover:-translate-y-1 transition-all duration-200 flex flex-col">
          <div class="flex justify-between items-start mb-4">
            <svg class="w-7 h-7 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
            <div class="flex gap-3">
              <a href={project.github} class="text-zinc-500 hover:text-zinc-200 transition-colors" aria-label="GitHub">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              </a>
              {project.live && (
                <a href={project.live} class="text-zinc-500 hover:text-zinc-200 transition-colors" aria-label="Live">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>
          <h3 class="font-semibold text-zinc-100 mb-2 group-hover:text-white transition-colors">{project.title}</h3>
          <p class="text-zinc-500 text-sm leading-relaxed flex-1">{project.description}</p>
          <div class="flex flex-wrap gap-2 mt-4">
            {project.tags.map(tag => (
              <span class="font-mono text-xs text-zinc-500">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
