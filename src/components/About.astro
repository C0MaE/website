---
import { fetchData } from '../lib/fetchData';

interface AboutData {
  paragraphs: string[];
}

const { paragraphs } = await fetchData<AboutData>('about.json');
---

<section id="about" class="py-32 px-6">
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">

    <!-- Text -->
    <div class="reveal">
      <p class="font-mono text-accent-light text-xs tracking-widest uppercase mb-4">01. About me</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-100 mb-6">
        A little bit<br />about myself
      </h2>
      <div class="space-y-4 text-zinc-400 leading-relaxed">
        {paragraphs.map(p => (
          <p set:html={p} />
        ))}
      </div>
    </div>

    <!-- Card / avatar area -->
    <div class="reveal flex justify-center">
      <div class="relative group">
        <!-- Avatar placeholder -->
        <div class="w-64 h-64 rounded-2xl bg-zinc-900 border border-zinc-800 flex items-center justify-center overflow-hidden">
          <svg class="w-32 h-32 text-zinc-700" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
          </svg>
        </div>

        <!-- Decorative border offset -->
        <div class="absolute -z-10 inset-0 translate-x-3 translate-y-3 rounded-2xl border border-accent/40 group-hover:translate-x-4 group-hover:translate-y-4 transition-transform duration-300" />
      </div>
    </div>

  </div>
</section>
